# StudyPartner — Environment Variables
# Copy this to .env and fill in your values. NEVER commit .env itself.

# Required: Your Gemini API key
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Required: Your GCP project ID
GCP_PROJECT_ID=

# Optional: Cloud Run region (default: us-west1)
GCP_REGION=us-west1
